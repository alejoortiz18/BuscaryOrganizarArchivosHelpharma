@model List<ArchivosNas.Models.Dto.ResultadoBusquedaDto>

<hr />
<a href="@Url.Action("Index", "Home")" class="btn btn-secondary mb-3">
    ← Volver
</a>

<h3>Resultados</h3>

<p>Total encontrados: @ViewBag.Total</p>

<div class="d-flex align-items-center gap-3">

    <button type="button" class="btn btn-success" onclick="iniciarDescarga()">
        Descargar todos
    </button>

    <div class="progress" style="width:300px;">
        <div id="barraProgreso" class="progress-bar" role="progressbar" style="width: 0%">
            0%
        </div>
    </div>

</div>

<!-- 🔥 Inputs ocultos con filtros -->
<input type="hidden" id="fNombreArchivo" value="@ViewBag.NombreArchivo" />
<input type="hidden" id="fPrefijo" value="@ViewBag.Prefijo" />
<input type="hidden" id="fNumeroFactura" value="@ViewBag.NumeroFactura" />


<hr />

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nombre</th>
            <th>Extension</th>
            <th>Prefijo</th>
            <th>Factura</th>
            <th>Ruta</th>
            <th>Abrir</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.NombreArchivo</td>
                <td>@item.Extension</td>
                <td>@item.Prefijo</td>
                <td>@item.NumeroFactura</td>
                <td>@item.RutaCompleta</td>
                <td>
                    <a asp-action="AbrirArchivo"
                           asp-controller="Home"
                           asp-route-ruta="@item.RutaCompleta"
                           asp-route-nombre="@item.NombreArchivo"
                           class="btn btn-success">
                        Abrir
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

<hr />

@{
    int total = ViewBag.Total ?? 0;
    int pagina = ViewBag.Pagina ?? 1;
    int pageSize = ViewBag.PageSize ?? 20;

    int totalPaginas = (int)Math.Ceiling((double)total / pageSize);

    int inicio = Math.Max(1, pagina - 2);
    int fin = Math.Min(totalPaginas, pagina + 2);
}

<nav>
    <ul class="pagination">

        <!-- Anterior -->
        @if (pagina > 1)
        {
            <li class="page-item">
                <form method="post" asp-action="Buscar">
                    <input type="hidden" name="Pagina" value="@(pagina - 1)" />
                    <input type="hidden" name="NombreArchivo" value="@ViewBag.NombreArchivo" />
                    <input type="hidden" name="Prefijo" value="@ViewBag.Prefijo" />
                    <input type="hidden" name="NumeroFactura" value="@ViewBag.NumeroFactura" />
                    <button class="page-link">Anterior</button>
                </form>
            </li>
        }

        <!-- Primera página -->
        <li class="page-item @(pagina == 1 ? "active" : "")">
            <form method="post" asp-action="Buscar">
                <input type="hidden" name="Pagina" value="1" />
                <input type="hidden" name="NombreArchivo" value="@ViewBag.NombreArchivo" />
                <input type="hidden" name="Prefijo" value="@ViewBag.Prefijo" />
                <input type="hidden" name="NumeroFactura" value="@ViewBag.NumeroFactura" />
                <button class="page-link">1</button>
            </form>
        </li>

        <!-- ... antes -->
        @if (inicio > 2)
        {
            <li class="page-item disabled">
                <span class="page-link">...</span>
            </li>
        }

        <!-- Páginas centrales -->
        @for (int i = inicio; i <= fin; i++)
        {
            if (i != 1 && i != totalPaginas)
            {
                <li class="page-item @(i == pagina ? "active" : "")">
                    <form method="post" asp-action="Buscar">
                        <input type="hidden" name="Pagina" value="@i" />
                        <input type="hidden" name="NombreArchivo" value="@ViewBag.NombreArchivo" />
                        <input type="hidden" name="Prefijo" value="@ViewBag.Prefijo" />
                        <input type="hidden" name="NumeroFactura" value="@ViewBag.NumeroFactura" />
                        <button class="page-link">@i</button>
                    </form>
                </li>
            }
        }

        <!-- ... después -->
        @if (fin < totalPaginas - 1)
        {
            <li class="page-item disabled">
                <span class="page-link">...</span>
            </li>
        }

        <!-- Última página -->
        @if (totalPaginas > 1)
        {
            <li class="page-item @(pagina == totalPaginas ? "active" : "")">
                <form method="post" asp-action="Buscar">
                    <input type="hidden" name="Pagina" value="@totalPaginas" />
                    <input type="hidden" name="NombreArchivo" value="@ViewBag.NombreArchivo" />
                    <input type="hidden" name="Prefijo" value="@ViewBag.Prefijo" />
                    <input type="hidden" name="NumeroFactura" value="@ViewBag.NumeroFactura" />
                    <button class="page-link">@totalPaginas</button>
                </form>
            </li>
        }

        <!-- Siguiente -->
        @if (pagina < totalPaginas)
        {
            <li class="page-item">
                <form method="post" asp-action="Buscar">
                    <input type="hidden" name="Pagina" value="@(pagina + 1)" />
                    <input type="hidden" name="NombreArchivo" value="@ViewBag.NombreArchivo" />
                    <input type="hidden" name="Prefijo" value="@ViewBag.Prefijo" />
                    <input type="hidden" name="NumeroFactura" value="@ViewBag.NumeroFactura" />
                    <button class="page-link">Siguiente</button>
                </form>
            </li>
        }

    </ul>
</nav>

<script>
    let jobId = null;
    let intervalo;

    function iniciarDescarga() {

        const data = {
            NombreArchivo: document.getElementById("fNombreArchivo")?.value || "",
            Prefijo: document.getElementById("fPrefijo")?.value || "",
            NumeroFactura: document.getElementById("fNumeroFactura")?.value || ""
        };

        fetch('/Home/IniciarZipDesdeBusqueda', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(data)
        })
        .then(r => {
            if (!r.ok) throw new Error("Error iniciando descarga");
            return r.json();
        })
        .then(data => {
            jobId = data.jobId;

            if (!jobId) {
                console.error("No se recibió jobId");
                return;
            }

            intervalo = setInterval(actualizarProgreso, 500);
        })
        .catch(err => {
            console.error(err);
            alert("Error iniciando la descarga");
        });
    }

    function actualizarProgreso() {

        if (!jobId) return;

        fetch('/Home/ProgresoZip?jobId=' + jobId)
            .then(r => r.json())
            .then(data => {

                let barra = document.getElementById("barraProgreso");

                if (!barra) return;

                barra.style.width = data.porcentaje + "%";
                barra.innerText = data.porcentaje + "%";

                if (data.porcentaje >= 100) {
                    clearInterval(intervalo);

                    window.location = '/Home/DescargarZipFinal?jobId=' + jobId;
                }
            })
            .catch(err => {
                console.error("Error consultando progreso", err);
                clearInterval(intervalo);
            });
    }
</script>
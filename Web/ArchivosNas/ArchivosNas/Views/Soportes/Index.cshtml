@{
    ViewBag.Title = "Carga Masiva Manual";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <h2 class="mb-4">Carga Manual de Soportes</h2>

    <form asp-action="Procesar" method="post" enctype="multipart/form-data" onsubmit="reindexar()">

        <table class="table table-bordered" id="tabla">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Soporte</th>
                    <th>Archivo PDF</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody id="tbody">
                <tr>
                    <td>1</td>
                    <td>
                        <input name="Items[0].Soporte" class="form-control" />
                    </td>
                    <td>
                        <input type="file" name="Items[0].Archivo" class="form-control" accept=".pdf" />
                    </td>
                    <td>
                        <button type="button" class="btn btn-danger" onclick="eliminarFila(this)">X</button>
                    </td>
                </tr>
            </tbody>
        </table>

        <button type="button" class="btn btn-primary mb-3" onclick="agregarFila()">
            + Agregar fila
        </button>

        <br />

        <button type="submit" class="btn btn-success">
            Procesar
        </button>

    </form>

    <hr />

    @if (ViewBag.Resultados != null)
    {
        <h4>Resultados</h4>
        <ul class="list-group">
            @foreach (var item in ViewBag.Resultados)
            {
                <li class="list-group-item">@item</li>
            }
        </ul>
    }

</div>

<script>
    let contador = 1;
    const maxFilas = 15;

    function agregarFila() {

        if (contador >= maxFilas) {
            alert("Máximo 15 soportes");
            return;
        }

        const tbody = document.getElementById("tbody");

        const fila = `
        <tr>
            <td>${contador + 1}</td>
            <td>
                <input name="Items[${contador}].Soporte" class="form-control" />
            </td>
            <td>
                <input type="file" name="Items[${contador}].Archivo" class="form-control" accept=".pdf" />
            </td>
            <td>
                <button type="button" class="btn btn-danger" onclick="eliminarFila(this)">X</button>
            </td>
        </tr>
        `;

        tbody.insertAdjacentHTML('beforeend', fila);
        contador++;
    }

    function eliminarFila(btn) {
        btn.closest("tr").remove();
    }
</script>
<script>
    function reindexar() {
        const filas = document.querySelectorAll("#tbody tr");

        filas.forEach((fila, index) => {

            fila.querySelector("td:first-child").innerText = index + 1;

            fila.querySelectorAll("input").forEach(input => {
                if (input.name.includes("Soporte")) {
                    input.name = `Items[${index}].Soporte`;
                }
                if (input.name.includes("Archivo")) {
                    input.name = `Items[${index}].Archivo`;
                }
            });
        });
    }
</script>